{
  "buildCommand": "cd VinPoker && npm run build",
  "outputDirectory": "VinPoker/dist",
  "installCommand": "cd VinPoker && npm install",
  "framework": "vite",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ]
}
