# Copy this file to .env.local and fill in real values for local development.
# .env.local is gitignored and won't be committed.

# E2E test user (Lovable Cloud auth) — required for `npm run test:e2e`
E2E_EMAIL=test@example.com
E2E_PASSWORD=changeme

# Sentry error monitoring (optional — production only)
# Get DSN from https://sentry.io → Project Settings → Client Keys (DSN)
VITE_SENTRY_DSN=
