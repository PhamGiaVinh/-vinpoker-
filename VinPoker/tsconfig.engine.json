{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["vitest/globals", "node"],
    "strict": true,
    "strictNullChecks": true,
    "noUnusedLocals": false,
    "paths": {
      "@engine/*": ["./supabase/functions/_shared/pokerEngine/*"]
    }
  },
  "include": [
    "supabase/functions/_shared/pokerEngine",
    "supabase/functions/_shared/pokerAdapter",
    "supabase/functions/_shared/pokerRuntime",
    "tests/pokerEngine",
    "tests/pokerAdapter"
  ]
}
