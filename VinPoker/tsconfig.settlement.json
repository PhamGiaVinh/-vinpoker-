{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["vitest/globals", "node"],
    "strict": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "paths": {
      "@/*": ["./src/*"],
      "@settlement/*": ["./supabase/functions/_shared/trackerSettlement/*"]
    }
  },
  "include": [
    "supabase/functions/_shared/trackerSettlement",
    "tests/trackerSettlement"
  ]
}
