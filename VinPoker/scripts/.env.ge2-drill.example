# GE-2 online-poker G4 drill — env template.
# Copy to scripts/.env.ge2-drill.local (gitignored via .env.*.local) and fill in.
# NEVER commit real values. NONE of these is a service_role key:
#   - SUPABASE_ANON_KEY is the public/publishable key (safe in any client).
#   - P1/P2 are DISPOSABLE throwaway test accounts (not real players).
# All privileged steps (disposable table create/teardown, chip-conservation-FAIL,
# race_lost) go through the operator's Management-API keyring token, NOT this file.

SUPABASE_URL=https://orlesggcjamwuknxwcpk.supabase.co
SUPABASE_ANON_KEY=

# Two disposable test logins (used only for the Edge-path cases)
P1_EMAIL=
P1_PASSWORD=
P2_EMAIL=
P2_PASSWORD=

# Disposable table UUID — created by scripts/ge2-drill/sql/01_setup_disposable_table.sql
TABLE_ID=

# Optional: per-seat buy-in (default 10000 play chips)
# BUYIN=10000
