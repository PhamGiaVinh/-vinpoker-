# Copy to scripts/.env.test.local (gitignored) and fill in. NEVER commit real values.
# Run a script with:  node --env-file=scripts/.env.test.local scripts/<script>.mjs

# Supabase
SUPABASE_URL=https://orlesggcjamwuknxwcpk.supabase.co
SUPABASE_ANON_KEY=                 # publishable/anon key (public)
SUPABASE_SERVICE_ROLE_KEY=         # service role key (SECRET — keep out of git)

# Direct Postgres (seed-swing-test.mjs) — password is REQUIRED, the rest have defaults
SUPABASE_DB_PASSWORD=              # database password (SECRET — rotate in Supabase dashboard)
# SUPABASE_DB_HOST=db.orlesggcjamwuknxwcpk.supabase.co
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_USER=cli_login_postgres
# SUPABASE_DB_NAME=postgres

# Telegram Bot
TELEGRAM_BOT_TOKEN=                # 123456:ABC...  (SECRET)
TELEGRAM_WEBHOOK_SECRET=          # (SECRET)

# Telegram Chat IDs
TELEGRAM_GROUP_CHAT_ID=-100...     # Group chat (nhận batch swing)
TELEGRAM_FM_CHAT_ID=123456789      # Floor Manager DM (nhận alert)

# Club
CLUB_ID=                           # uuid của club test
